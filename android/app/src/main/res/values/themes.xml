<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark, no action bar. windowBackground matches the web splash (#0E0E10) so the
         cold-start shows the brand colour instead of a white flash. -->
    <style name="Theme.SenseLink" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/sense_bg</item>
        <item name="android:statusBarColor">@color/sense_bg</item>
        <item name="android:navigationBarColor">@color/sense_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
